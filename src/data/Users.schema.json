{
    "name": "User",
    "attributes": [
      { "name": "id", "domain": "SERIAL" },
      { "name": "username", "domain": "STRING" },
      { "name": "email", "domain": "STRING" },
      { "name": "password", "domain": "STRING" },
      { "name": "created_at", "domain": "DATE" },
      { "name": "updated_at", "domain": "DATE" }
    ],
    "constraints": {
      "primaryKey": ["id"],
      "notNull": ["id", "username", "email", "password", "created_at", "updated_at"],
      "unique": [
        ["id"]
      ],
      "checks": [
        { "expr": "created_at <= updated_at" }
      ],
      "foreignKeys": []
    }
  }